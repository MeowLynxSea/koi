#!/usr/bin/env bun

/**
 * Koi CLI Entry Point
 *
 * Deeply customized coding agent built on top of Pi SDK.
 * TUI + Bun runtime.
 * 
 * Uses createRequire to correctly locate the package regardless of
 * whether it's installed globally or locally.
 */

import { createRequire } from "module";
import { dirname, join } from "path";
import { fileURLToPath } from "url";

// Find the package directory correctly in both dev and release modes
const require = createRequire(import.meta.url);
const packageJsonPath = require.resolve("@meowlynxsea/koi/package.json");
const packageDir = dirname(dirname(packageJsonPath));

// Import main from the package's dist directory
const { main } = await import(join(packageDir, "dist/main.js"));

await main();
