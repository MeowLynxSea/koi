{
  "name": "@meowlynxsea/koi",
  "version": "0.2.20",
  "description": "A coding agent built on Pi SDK with TUI + Bun runtime",
  "module": "src/main.tsx",
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/meowlynxsea/koi"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "native",
    "src/main.tsx",
    "src/cce",
    "!src/cce/web/frontend/node_modules",
    "!src/cce/web/frontend/dist",
    "!src/cce/web/frontend/public",
    "!src/cce/web/frontend/src",
    "!src/cce/web/frontend/*.config.*",
    "!src/cce/web/frontend/package.json",
    "!src/cce/web/frontend/bun.lock",
    "!src/cce/web/frontend/index.html",
    "src/skills",
    "src/tools",
    "src/styles.css",
    "src/commands",
    "src/mcp",
    "src/providers",
    "NOTICE"
  ],
  "scripts": {
    "dev": "bun run src/main.tsx",
    "postinstall": "bun run scripts/postinstall.ts",
    "build": "bun build src/main.tsx --outdir dist --target bun && cp node_modules/@opentui/core/parser.worker.js dist/ && cp -r node_modules/@opentui/core/assets dist/opentui-assets && mkdir -p dist/cce-frontend && [ -d src/cce/web/frontend/dist ] && cp -r src/cce/web/frontend/dist/* dist/cce-frontend/ || true && cp src/cce/core/schema.sql dist/ && bun run scripts/postbuild.ts",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "bin": {
    "koi": "./bin/koi"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "bun": "^1.3.12",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.0",
    "@mariozechner/clipboard": "^0.3.5",
    "@mariozechner/pi-agent-core": "0.73.0",
    "@mariozechner/pi-ai": "0.73.0",
    "@mariozechner/pi-coding-agent": "0.73.0",
    "@mariozechner/pi-tui": "0.73.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentui-ui/dialog": "latest",
    "@opentui/core": "latest",
    "@opentui/core-darwin-x64": "^0.2.7",
    "@opentui/core-linux-arm64": "0.2.7",
    "@opentui/core-linux-x64": "0.2.7",
    "@opentui/core-win32-arm64": "0.2.7",
    "@opentui/core-win32-x64": "0.2.7",
    "@opentui/react": "latest",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.6.2",
    "axios": "^1.16.0",
    "clipboard-image": "^0.1.0",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "fast-glob": "^3.3.3",
    "jimp": "^1.6.1",
    "react": "^19.2.6",
    "turndown": "^7.2.4"
  },
  "trustedDependencies": [
    "@google/genai",
    "bun",
    "koffi",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}
